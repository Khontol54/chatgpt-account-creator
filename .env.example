# ============================================================
# ChatGPT Account Creator Bot – example environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# ---- OpenAI / ChatGPT ----------------------------------
SIGNUP_URL=https://chat.openai.com/auth/login
API_URL=https://api.openai.com

# ---- Browser -------------------------------------------
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ---- Proxy (optional) ----------------------------------
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ---- Email ---------------------------------------------
# Provider: tempmail | gmail | custom
EMAIL_PROVIDER=tempmail
GMAIL_USERNAME=
GMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ---- Database ------------------------------------------
DB_PATH=./data/accounts.db

# ---- Rate limiting -------------------------------------
RATE_LIMIT_PER_DAY=5
DELAY_BETWEEN=60

# ---- Logging -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ---- API Server ----------------------------------------
PORT=3000
HOST=localhost
